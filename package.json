{
  "name": "nuxt-tailwind-breakpoints",
  "version": "3.0.1",
  "description": "Show Tailwind CSS Breakpoints during Nuxt development (compatible with Nuxt 3 & 4 and Tailwind CSS 3 & 4)",
  "repository": {
    "type": "git",
    "url": "git@github.com:kswedberg/nuxt-tailwind-breakpoints.git"
  },
  "license": "MIT",
  "type": "module",
  "exports": {
    ".": {
      "types": "./dist/types.d.mts",
      "import": "./dist/module.mjs"
    }
  },
  "main": "./dist/module.mjs",
  "files": [
    "dist"
  ],
  "keywords": [
    "nuxt",
    "tailwind",
    "tailwindcss",
    "module",
    "breakpoints",
    "responsive design"
  ],
  "scripts": {
    "prepack": "nuxt-module-build build",
    "dev": "nuxi dev playground",
    "dev:build": "cd playground && nuxi build",
    "dev:prepare": "nuxt-module-build build --stub && nuxi prepare playground",
    "release": "npm run lint && npm run test && npm run prepack && changelogen --release && npm publish && git push --follow-tags",
    "lint": "eslint .",
    "test": "vitest run",
    "test:watch": "vitest watch"
  },
  "dependencies": {
    "@nuxt/kit": "^4.4.6"
  },
  "peerDependencies": {
    "tailwindcss": "^3.0.0 || ^4.0.0"
  },
  "peerDependenciesMeta": {
    "tailwindcss": {
      "optional": true
    }
  },
  "devDependencies": {
    "@nuxt/eslint": "^1.15.2",
    "@nuxt/eslint-config": "^1.15.2",
    "@nuxt/module-builder": "^1.0.2",
    "@nuxt/schema": "^4.4.6",
    "@nuxt/test-utils": "^4.0.3",
    "@tailwindcss/vite": "^4.3.0",
    "@types/node": "^25.9.0",
    "changelogen": "^0.6.2",
    "eslint": "^10.4.0",
    "eslint-config-kswedberg": "^7.3.2",
    "eslint-plugin-import": "^2.28.1",
    "eslint-plugin-promise": "^7.3.0",
    "eslint-plugin-vue": "^10.9.1",
    "nuxt": "^4.4.6",
    "tailwindcss": "^4.3.0",
    "vitest": "^4.1.6",
    "vue-tsc": "^3.3.0"
  }
}
